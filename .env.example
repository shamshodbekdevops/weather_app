# Copy this file to .env and replace the values with your own secrets.
SECRET_KEY=replace-with-your-django-secret-key
OPENWEATHER_API_KEY=replace-with-your-openweather-api-key
DEBUG=False
ALLOWED_HOSTS=your-app.up.railway.app,localhost,127.0.0.1

# Optional email settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=replace-with-your-email-password
DEFAULT_FROM_EMAIL=you@example.com
